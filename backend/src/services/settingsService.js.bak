// settingsService.js — per-tenant settings, trial management, billing
const fs   = require('fs');
const path = require('path');

const SETTINGS_DIR = process.env.NODE_ENV === 'production'
  ? '/home/settings'
  : path.join(__dirname, '../../../settings');

if (!fs.existsSync(SETTINGS_DIR)) fs.mkdirSync(SETTINGS_DIR, { recursive: true });

// ─── Default settings ─────────────────────────────────────────────────────
function defaultSettings(tenantId) {
  const trialEnd = new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString();
  return {
    tenantId,
    createdAt:  new Date().toISOString(),
    updatedAt:  new Date().toISOString(),

    // ── Billing / Trial ──────────────────────────────────────────────────
    billing: {
      plan:          'trial',       // 'trial' | 'active' | 'expired' | 'cancelled'
      trialStarted:  new Date().toISOString(),
      trialEndsAt:   trialEnd,
      pricePerMonth: 10,
      currency:      'USD',
      tenantCount:   1
    },

    // ── Admins (multi-admin support) ─────────────────────────────────────
    admins: [
      // { email, name, role: 'owner'|'admin'|'viewer', addedAt, telegramChatId }
    ],

    // ── Notifications ─────────────────────────────────────────────────────
    notifications: {
      adminEmails:       [],
      userNotify:        true,
      emailOnSeverity:   ['critical', 'high', 'medium'],
      // Telegram per-admin (each admin can have their own bot)
      telegramBotToken:  process.env.TELEGRAM_BOT_TOKEN || '',
      telegramChatId:    process.env.TELEGRAM_CHAT_ID  || '',
      telegramOnSeverity: ['critical', 'high']
    },

    // ── Detection Rules ───────────────────────────────────────────────────
    detectionRules: {
      NEW_IP:            { enabled: true,  severity: 'medium'   },
      NEW_COUNTRY:       { enabled: true,  severity: 'high'     },
      UNKNOWN_DEVICE:    { enabled: true,  severity: 'medium'   },
      IMPOSSIBLE_TRAVEL: { enabled: true,  severity: 'critical' },
      OFF_HOURS:         { enabled: false, severity: 'low'      },
      FAILED_MFA:        { enabled: true,  severity: 'high'     },
      HIGH_RISK:         { enabled: true,  severity: 'critical' }
    },

    // ── Work Hours / Business Hours ──────────────────────────────────────
    workHours: {
      timezone:   'Asia/Jerusalem',
      startHour:  7,
      endHour:    20,
      workDays:   [0, 1, 2, 3, 4],
      slaMode: 'business_hours',
      criticalRuns24x7: true,
      quietHoursEnabled: false,
      quietStartHour: 22,
      quietEndHour: 6
    },
    businessHours: {
      timezone:   'Asia/Jerusalem',
      startHour:  7,
      endHour:    20,
      workDays:   [0, 1, 2, 3, 4],
      slaMode: 'business_hours',
      criticalRuns24x7: true,
      quietHoursEnabled: false,
      quietStartHour: 22,
      quietEndHour: 6
    },

    // ── Auto-Actions ──────────────────────────────────────────────────────
    autoActions: {
      critical: { revokeSession: true,  disableUser: false, telegramPlaybook: true  },
      high:     { revokeSession: true,  disableUser: false, telegramPlaybook: true  },
      medium:   { revokeSession: false, disableUser: false, telegramPlaybook: false },
      low:      { revokeSession: false, disableUser: false, telegramPlaybook: false }
    },

    // ── Whitelist ─────────────────────────────────────────────────────────
    whitelist: {
      ips:       [],   // ['1.2.3.4', '10.0.0.0/8']
      countries: [],   // ['Israel', 'United States']
      devices:   [],   // device IDs or names
      users:     []    // UPNs to exclude from monitoring
    },

    // ── Monitored Roles ───────────────────────────────────────────────────
    monitoredRoles: [
      'Global Administrator',
      'Intune Administrator',
      'Cloud Device Administrator',
      'Privileged Role Administrator'
    ],

    policyPack: 'balanced',
    escalation: {
      enabled: true,
      criticalMinutes: 30,
      highMinutes: 120,
      notifyRoles: ['owner', 'admin', 'msp_operator']
    },
    approvalPolicies: {
      critical: ['responder', 'admin', 'owner'],
      high: ['responder', 'admin'],
      medium: ['analyst'],
      low: ['analyst']
    },
    assignmentRules: {
      enabled: true,
      severityOwners: {
        critical: 'soc-lead@modernendpoint.tech',
        high: 'identity-admin@modernendpoint.tech',
        medium: 'analyst@modernendpoint.tech',
        low: 'analyst@modernendpoint.tech'
      },
      defaultOwner: 'analyst@modernendpoint.tech'
    },
    runbooks: {
      critical: [
        'Validate sign-in context and correlated alerts',
        'Trigger session revoke if user risk remains elevated',
        'Escalate to tenant owner for emergency approval'
      ],
      high: [
        'Review sign-in evidence and confirm device posture',
        'Notify owner and responder lane',
        'Queue revoke playbook if not acknowledged in SLA window'
      ],
      medium: [
        'Review anomaly details',
        'Add comment and assign analyst',
        'Monitor for repeat activity'
      ],
      low: ['Monitor only']
    },
    orchestrationPolicies: {
      allowCrossTenantSweep: true,
      allowBulkNotify: true,
      requireApprovalForDisable: true,
      maxTenantsPerRun: 10
    },
    responsePolicies: {
      critical: { slaMinutes: 30, autoContain: true, requireApproval: true, notifyRoles: ['owner', 'admin', 'responder'], allowedActions: ['monitor', 'revoke', 'disable'] },
      high:     { slaMinutes: 120, autoContain: false, requireApproval: true, notifyRoles: ['owner', 'admin'], allowedActions: ['monitor', 'revoke'] },
      medium:   { slaMinutes: 240, autoContain: false, requireApproval: false, notifyRoles: ['analyst'], allowedActions: ['monitor'] },
      low:      { slaMinutes: 480, autoContain: false, requireApproval: false, notifyRoles: ['analyst'], allowedActions: ['monitor'] }
    },
    suppressionRules: [],
    responseExceptions: {
      rolesRequireApproval: ['Global Administrator', 'Privileged Role Administrator'],
      blockedActionsByRole: {
        'Break Glass Account': ['disable'],
        'Emergency Access': ['disable']
      }
    },
    retentionPolicy: {
      incidentDays: 180,
      auditDays: 365,
      reportDays: 365,
      includeDismissedInTrend: true
    }
  };
}

// ─── Get settings ─────────────────────────────────────────────────────────
function getSettings(tenantId) {
  const filePath = path.join(SETTINGS_DIR, tenantId + '.json');
  if (!fs.existsSync(filePath)) return defaultSettings(tenantId);
  try {
    const data = JSON.parse(fs.readFileSync(filePath, 'utf8'));
    // Migrate old settings that don't have billing/admins
    if (!data.billing)   data.billing   = defaultSettings(tenantId).billing;
    if (!data.admins)    data.admins    = [];
    if (!data.workHours) data.workHours = defaultSettings(tenantId).workHours;
    if (!data.businessHours) data.businessHours = data.workHours || defaultSettings(tenantId).businessHours;
    if (data.workHours && !data.businessHours) data.businessHours = data.workHours;
    if (!data.policyPack) data.policyPack = defaultSettings(tenantId).policyPack;
    if (!data.escalation) data.escalation = defaultSettings(tenantId).escalation;
    if (!data.approvalPolicies) data.approvalPolicies = defaultSettings(tenantId).approvalPolicies;
    if (!data.assignmentRules) data.assignmentRules = defaultSettings(tenantId).assignmentRules;
    if (!data.runbooks) data.runbooks = defaultSettings(tenantId).runbooks;
    if (!data.orchestrationPolicies) data.orchestrationPolicies = defaultSettings(tenantId).orchestrationPolicies;
    if (!data.responsePolicies) data.responsePolicies = defaultSettings(tenantId).responsePolicies;
    if (!data.suppressionRules) data.suppressionRules = defaultSettings(tenantId).suppressionRules;
    if (!data.responseExceptions) data.responseExceptions = defaultSettings(tenantId).responseExceptions;
    if (!data.retentionPolicy) data.retentionPolicy = defaultSettings(tenantId).retentionPolicy;
    return data;
  } catch (e) {
    return defaultSettings(tenantId);
  }
}

// ─── Save settings ────────────────────────────────────────────────────────
function saveSettings(tenantId, updates) {
  const current = getSettings(tenantId);
  const merged  = deepMerge(current, updates);
  if (merged.workHours && !merged.businessHours) merged.businessHours = merged.workHours;
  if (merged.businessHours && !merged.workHours) merged.workHours = merged.businessHours;
  merged.tenantId  = tenantId;
  merged.updatedAt = new Date().toISOString();
  fs.writeFileSync(path.join(SETTINGS_DIR, tenantId + '.json'), JSON.stringify(merged, null, 2));
  return merged;
}

// ─── Trial helpers ────────────────────────────────────────────────────────
function getTrialStatus(tenantId) {
  const s = getSettings(tenantId);
  const billing = s.billing || {};
  const now = Date.now();

  if (billing.plan === 'active')    return { status: 'active',   daysLeft: null };
  if (billing.plan === 'cancelled') return { status: 'cancelled', daysLeft: 0 };

  const trialEnd = new Date(billing.trialEndsAt || 0).getTime();
  const daysLeft = Math.max(0, Math.ceil((trialEnd - now) / (24 * 60 * 60 * 1000)));

  if (billing.plan === 'trial' && daysLeft > 0) return { status: 'trial', daysLeft };
  return { status: 'expired', daysLeft: 0 };
}

function isTrialOrActive(tenantId) {
  const { status } = getTrialStatus(tenantId);
  return status === 'trial' || status === 'active';
}

// ─── Admin helpers ────────────────────────────────────────────────────────
function addAdmin(tenantId, admin) {
  const s = getSettings(tenantId);
  if (!s.admins) s.admins = [];
  const exists = s.admins.find(a => a.email === admin.email);
  if (!exists) s.admins.push({ ...admin, addedAt: new Date().toISOString() });
  return saveSettings(tenantId, { admins: s.admins });
}

function removeAdmin(tenantId, email) {
  const s = getSettings(tenantId);
  s.admins = (s.admins || []).filter(a => a.email !== email);
  return saveSettings(tenantId, { admins: s.admins });
}

function getAdmins(tenantId) {
  return getSettings(tenantId).admins || [];
}

// ─── Work hours check ──────────────────────────────────────────────────────
function isOffHours(settings, dateStr) {
  const wh = settings.workHours;
  if (!wh) return false;
  try {
    const d = new Date(dateStr);
    const localHour = new Date(d.toLocaleString('en-US', { timeZone: wh.timezone })).getHours();
    const localDay  = new Date(d.toLocaleString('en-US', { timeZone: wh.timezone })).getDay();
    const isWorkDay = (wh.workDays || [0,1,2,3,4]).includes(localDay);
    const isWorkHour = localHour >= (wh.startHour || 7) && localHour < (wh.endHour || 20);
    return !isWorkDay || !isWorkHour;
  } catch (e) { return false; }
}

// ─── Whitelist check ──────────────────────────────────────────────────────
function isWhitelisted(settings, signIn, anomalyType) {
  const wl = settings.whitelist || {};
  if (wl.users    && wl.users.includes(signIn.userPrincipalName)) return true;
  if (wl.ips      && signIn.ipAddress && wl.ips.includes(signIn.ipAddress)) return true;
  const country = signIn.location?.countryOrRegion;
  if (wl.countries && country && wl.countries.includes(country)) return true;
  const deviceName = signIn.deviceDetail?.displayName;
  const deviceId   = signIn.deviceDetail?.deviceId;
  if (wl.devices) {
    if (deviceName && wl.devices.includes(deviceName)) return true;
    if (deviceId   && wl.devices.includes(deviceId))   return true;
  }
  return false;
}

function isRuleEnabled(settings, anomalyType) {
  return (settings.detectionRules?.[anomalyType]?.enabled) !== false;
}

function getEffectiveSeverity(settings, anomalyType) {
  return settings.detectionRules?.[anomalyType]?.severity || 'medium';
}

function getAdminEmails(settings) {
  const emails = [...(settings.notifications?.adminEmails || [])];
  // Also include all admins with 'admin' or 'owner' role
  for (const admin of (settings.admins || [])) {
    if (['owner', 'admin'].includes(admin.role) && admin.email && !emails.includes(admin.email)) {
      emails.push(admin.email);
    }
  }
  return emails;
}

function deepMerge(target, source) {
  const result = Object.assign({}, target);
  for (const key of Object.keys(source)) {
    if (source[key] && typeof source[key] === 'object' && !Array.isArray(source[key])) {
      result[key] = deepMerge(target[key] || {}, source[key]);
    } else {
      result[key] = source[key];
    }
  }
  return result;
}

module.exports = {
  getSettings, saveSettings,
  getTrialStatus, isTrialOrActive,
  addAdmin, removeAdmin, getAdmins,
  isWhitelisted, isRuleEnabled, getEffectiveSeverity,
  getAdminEmails, isOffHours, defaultSettings
};
