# ─── Azure AD App Registration ──────────────────────────────────────────────
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
# Optional explicit shared Defender app credentials. If omitted, CLIENT_ID/CLIENT_SECRET are used.
DEFENDER_SHARED_CLIENT_ID=your-client-id
DEFENDER_SHARED_CLIENT_SECRET=your-client-secret

# ─── URLs ────────────────────────────────────────────────────────────────────
REDIRECT_URI=https://identitymonitor.modernendpoint.tech/api/auth/callback
FRONTEND_URL=https://identitymonitor.modernendpoint.tech
WEBAPP_REMEDIATION_BASE_URL=https://app.modernendpoint.tech

# ─── External remediation shared token ──────────────────────────────────────
# Must match the Webapp REMEDIATION_SHARED_TOKEN exactly.
WEBAPP_REMEDIATION_TOKEN=change-this-to-the-same-shared-token-used-by-webapp
# Backward-compatible fallback still supported by the code:
REMEDIATION_SHARED_TOKEN=

# ─── Email Alerts ────────────────────────────────────────────────────────────
ALERT_SENDER_EMAIL=alerts@yourdomain.com
ALERT_ADMIN_EMAIL=admin@yourdomain.com

# ─── Azure Table Storage (persistent alerts + baselines) ────────────────────
# Azure Portal → Storage Account → Access keys → Connection string
# Cost: ~$0/month at this scale
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_TENANT_TABLE=TenantIntegrations
AZURE_STORAGE_BLOB_CONTAINER=tenant-snapshots

# ─── Graph Webhooks (real-time sign-in notifications) ───────────────────────
# Must be a PUBLIC HTTPS URL — your Azure App Service URL
WEBHOOK_NOTIFICATION_URL=https://identitymonitor.modernendpoint.tech/api/webhook/notify
WEBHOOK_CLIENT_STATE=change-this-to-a-random-secret

# ─── Telegram Bot (interactive security playbooks) ───────────────────────────
# 1. Message @BotFather → /newbot → copy token
# 2. Message @userinfobot → copy your chat_id
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Set Telegram webhook:
# https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://identitymonitor.modernendpoint.tech/api/webhook/telegram

# ─── App Settings ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string-32chars+
MOCK_MODE=false

# Optional: separate callback for admin consent (defaults to REDIRECT_URI)
ADMIN_CONSENT_REDIRECT_URI=https://yourdomain.example/api/auth/admin-consent/callback
